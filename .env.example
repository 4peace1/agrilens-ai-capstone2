# Copy to .env for local development (docker-compose reads these too).
AGRILENS_ENVIRONMENT=development
AGRILENS_GCP_PROJECT_ID=agrilens-dev
AGRILENS_DATABASE_URL=postgresql://agrilens:agrilens@localhost:5432/agrilens
AGRILENS_PUBSUB_TOPIC_IMAGE_PROCESSING=image-processing-topic
AGRILENS_PUBSUB_TOPIC_INFERENCE_RESULTS=inference-results-topic
AGRILENS_PUBSUB_SUBSCRIPTION_IMAGE_PROCESSING=image-processing-sub
AGRILENS_GCS_BUCKET_RAW=agrilens-raw-images
AGRILENS_GCS_BUCKET_PROCESSED=agrilens-processed-images
AGRILENS_INFERENCE_SERVICE_URL=http://localhost:8080
PUBSUB_EMULATOR_HOST=localhost:8085
STORAGE_EMULATOR_HOST=http://localhost:4443
